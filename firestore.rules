rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function tripPath(tripId) {
      return /databases/$(database)/documents/trips/$(tripId);
    }

    function tripExists(tripId) {
      return exists(tripPath(tripId));
    }

    function tripExistsAfter(tripId) {
      return existsAfter(tripPath(tripId));
    }

    function isOwner(tripId) {
      return signedIn()
        && tripExists(tripId)
        && get(tripPath(tripId)).data.ownerId == request.auth.uid;
    }

    function isOwnerAfter(tripId) {
      return signedIn()
        && tripExistsAfter(tripId)
        && getAfter(tripPath(tripId)).data.ownerId == request.auth.uid;
    }

    function isTripMemberByUid(tripId) {
      return signedIn()
        && exists(/databases/$(database)/documents/trips/$(tripId)/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/trips/$(tripId)/members/$(request.auth.uid)).data.status == "active";
    }

    function hasEmailAccess(tripId) {
      return signedIn()
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/emailAccess/$(request.auth.token.email)/trips/$(tripId))
        && get(/databases/$(database)/documents/emailAccess/$(request.auth.token.email)/trips/$(tripId)).data.status == "active";
    }

    function canReadTrip(tripId) {
      return signedIn()
        && (
          isOwner(tripId)
          || isTripMemberByUid(tripId)
          || hasEmailAccess(tripId)
        );
    }

    function canWriteTripData(tripId) {
      return canReadTrip(tripId) || isOwnerAfter(tripId);
    }

    function requestMemberKeys() {
      return request.auth.token.email == null
        ? [request.auth.uid]
        : [request.auth.uid, request.auth.token.email];
    }

    function isGroupBudget(data) {
      return !data.keys().hasAny(["scope"]) || data.scope == "group";
    }

    function canReadBudget(data) {
      return isGroupBudget(data)
        || (
          data.keys().hasAny(["visibleMemberIds"])
          && data.visibleMemberIds is list
          && data.visibleMemberIds.hasAny(requestMemberKeys())
        );
    }

    function canWriteBudget(data) {
      return data.scope in ["group", "selected", "me"]
        && data.estimatedEur is number
        && data.estimatedEur > 0
        && data.visibleMemberIds is list
        && (
          data.scope == "group"
          || data.visibleMemberIds.hasAny(requestMemberKeys())
        );
    }

    function isGroupExpense(data) {
      return !data.keys().hasAny(["scope"])
        || data.scope == "group"
        || data.visibleTo == "all"
        || data.countsTowardGroupSettlement == true;
    }

    function canReadExpense(tripId, data) {
      return isOwner(tripId)
        || isGroupExpense(data)
        || (
          data.keys().hasAny(["visibleTo"])
          && data.visibleTo is list
          && data.visibleTo.hasAny(requestMemberKeys())
        );
    }

    function canWriteExpense(data) {
      return !data.keys().hasAny(["scope"])
        || (
          data.scope in ["group", "selected_members", "personal"]
          && (
            data.visibleTo == "all"
            || (
              data.visibleTo is list
              && data.visibleTo.hasAny(requestMemberKeys())
            )
          )
          && (
            data.scope != "group"
            || data.visibleTo == "all"
            || data.countsTowardGroupSettlement == true
          )
        );
    }

    function isGroupSettlement(data) {
      return !data.keys().hasAny(["settlementLayer"])
        || data.settlementLayer == "group"
        || data.settlementMemberIds == "all";
    }

    function canReadSettlement(tripId, data) {
      return isOwner(tripId)
        || isGroupSettlement(data)
        || (
          data.keys().hasAny(["settlementMemberIds"])
          && data.settlementMemberIds is list
          && data.settlementMemberIds.hasAny(requestMemberKeys())
        )
        || data.fromMemberId in requestMemberKeys()
        || data.toMemberId in requestMemberKeys();
    }

    function canWriteSettlement(data) {
      return !data.keys().hasAny(["settlementLayer"])
        || (
          data.settlementLayer in ["group", "private"]
          && data.status in ["pending", "paid", "cancelled"]
          && (
            data.settlementMemberIds == "all"
            || (
              data.settlementMemberIds is list
              && data.settlementMemberIds.hasAny(requestMemberKeys())
            )
            || data.fromMemberId in requestMemberKeys()
            || data.toMemberId in requestMemberKeys()
          )
        );
    }

    function taskMemberCanSee(data) {
      return data.visibleTo == "all"
        || (
          data.keys().hasAny(["visibleTo"])
          && data.visibleTo is list
          && data.visibleTo.hasAny(requestMemberKeys())
        )
        || (
          data.keys().hasAny(["assignedTo"])
          && data.assignedTo is list
          && data.assignedTo.hasAny(requestMemberKeys())
        )
        || data.createdBy in requestMemberKeys();
    }

    function canReadTask(tripId, data) {
      return isOwner(tripId) || taskMemberCanSee(data);
    }

    function canCreateTask(tripId, data) {
      return canReadTrip(tripId)
        && data.tripId == tripId
        && data.title is string
        && data.title.size() > 0
        && data.type in ["general", "booking", "payment", "receipt", "packing", "document"]
        && data.scope in ["group", "selected_members", "personal"]
        && data.status in ["todo", "done"]
        && data.assignedTo is list
        && data.assignedTo.size() > 0
        && data.createdBy in requestMemberKeys()
        && (
          data.visibleTo == "all"
          || (
            data.visibleTo is list
            && data.visibleTo.hasAny(requestMemberKeys())
          )
        );
    }

    function canCompleteTask(data) {
      return data.createdBy in requestMemberKeys()
        || (
          data.keys().hasAny(["assignedTo"])
          && data.assignedTo is list
          && data.assignedTo.hasAny(requestMemberKeys())
        );
    }

    function isTaskStatusOnlyUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(["status", "completedBy", "completedAt", "updatedAt"])
        && request.resource.data.status in ["todo", "done"]
        && (
          request.resource.data.completedBy == null
          || request.resource.data.completedBy in requestMemberKeys()
        );
    }

    function isSelfUser(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isSelfEmail(email) {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email == email;
    }

    match /users/{userId} {
      allow get, create, update, delete: if isSelfUser(userId);
      allow list: if signedIn();
    }

    match /emailAccess/{email}/trips/{tripId} {
      allow get, list: if signedIn();
      allow create, update: if isSelfEmail(email) || isOwner(tripId) || isOwnerAfter(tripId);
      allow delete: if isSelfEmail(email) || isOwner(tripId);
    }

    match /trips/{tripId} {
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow get, list: if canReadTrip(tripId)
        || (signedIn() && resource.data.ownerId == request.auth.uid);
      allow update, delete: if isOwner(tripId);

      match /members/{memberId} {
        allow get, list: if canReadTrip(tripId) || isOwnerAfter(tripId);
        allow create, update: if isOwner(tripId)
          || isOwnerAfter(tripId)
          || (
            signedIn()
            && request.resource.data.userId == request.auth.uid
            && request.resource.data.role == "member"
          );
        allow delete: if isOwner(tripId);
      }

      match /categories/{categoryId} {
        allow get, list: if canReadTrip(tripId) || isOwnerAfter(tripId);
        allow create: if canWriteTripData(tripId);
        allow update, delete: if canReadTrip(tripId);
      }

      match /predictions/{predictionId} {
        allow get, list: if canReadTrip(tripId) && canReadBudget(resource.data);
        allow create: if canReadTrip(tripId) && canWriteBudget(request.resource.data);
        allow update: if canReadTrip(tripId)
          && canReadBudget(resource.data)
          && canWriteBudget(request.resource.data);
        allow delete: if canReadTrip(tripId) && canReadBudget(resource.data);
      }

      match /expenses/{expenseId} {
        allow get, list: if canReadTrip(tripId) && canReadExpense(tripId, resource.data);
        allow create: if canReadTrip(tripId) && canWriteExpense(request.resource.data);
        allow update: if canReadTrip(tripId)
          && canReadExpense(tripId, resource.data)
          && canWriteExpense(request.resource.data);
        allow delete: if canReadTrip(tripId) && canReadExpense(tripId, resource.data);
      }

      match /settlements/{settlementId} {
        allow get, list: if canReadTrip(tripId) && canReadSettlement(tripId, resource.data);
        allow create: if canReadTrip(tripId) && canWriteSettlement(request.resource.data);
        allow update: if canReadTrip(tripId)
          && canReadSettlement(tripId, resource.data)
          && canWriteSettlement(request.resource.data);
        allow delete: if canReadTrip(tripId) && canReadSettlement(tripId, resource.data);
      }

      match /tasks/{taskId} {
        allow get, list: if canReadTrip(tripId) && canReadTask(tripId, resource.data);
        allow create: if canCreateTask(tripId, request.resource.data);
        allow update: if canReadTrip(tripId)
          && canReadTask(tripId, resource.data)
          && (
            isOwner(tripId)
            || resource.data.createdBy in requestMemberKeys()
            || (canCompleteTask(resource.data) && isTaskStatusOnlyUpdate())
          );
        allow delete: if canReadTrip(tripId)
          && (isOwner(tripId) || resource.data.createdBy in requestMemberKeys());
      }

      match /settlementGroups/{groupId} {
        allow get, list: if canReadTrip(tripId);
        allow create, update, delete: if canReadTrip(tripId);
      }

      match /notifications/{notificationId} {
        allow get, list: if canReadTrip(tripId);
        allow create, update, delete: if canReadTrip(tripId);
      }

      match /invites/{inviteId} {
        allow get: if true;
        allow list: if canReadTrip(tripId);
        allow create, update, delete: if isOwner(tripId);
      }

      match /personalBudgets/{userId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }
    }
  }
}
